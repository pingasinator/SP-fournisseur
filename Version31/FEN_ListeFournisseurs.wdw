  procedures :
   -
     name : chargementListeFournisseur
     procedure_id : 1849158144527480613
     type_code : 14
     code : |1+
      //!
      //! @brief Affichage de la liste des fournisseurs
      //!
      //!
      procédure chargementListeFournisseur() <métier>
      
      TableSupprimeTout(TABLE_ListeFournisseurs)
      
      HLitPremier(Fournisseurs,id)
      si HTrouve(Fournisseurs) alors
      	tantque HEnDehors(Fournisseurs) = faux
      		TableAjoute(TABLE_ListeFournisseurs,Fournisseurs.id + TAB + Fournisseurs.raisonSociale + TAB + Fournisseurs.codePostal + TAB + Fournisseurs.ville + TAB + Fournisseurs.tel + TAB + Fournisseurs.adresseMail)
      		HLitSuivant(Fournisseurs,id)
      	FIN
      	
      sinon
      	LIB_MessageErreur = "Le fichier 'fournisseurs' est vide."
      fin
      
     type : 458752
