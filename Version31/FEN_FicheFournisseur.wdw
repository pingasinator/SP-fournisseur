  procedures :
   -
     name : afficherConsultation
     procedure_id : 1849192036139016342
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure afficherConsultation() <UI>
      
      GR_FicheFournisseur..EnSaisie = Faux
      GR_BtnFicheFournisseurConsultation..Visible = Vrai
      GR_BtnFicheFournisseurEdition..Visible = Faux
     type : 458752
   -
     name : chargementFicheFournisseur
     procedure_id : 1849193947406199486
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure chargementFicheFournisseur() <métier>
      
      HLitRecherchePremier(Fournisseurs,id,gIdFournisseurEnCours)
      si HTrouve(Fournisseurs) = vrai alors
      	fichierversecran(FEN_FicheFournisseur)
      	SAI_DateCreation = DateVersChaîne(Fournisseurs.dateCreation?? "JJJJ JJ MMM AAAA")
      	SAI_DateModification = DateVersChaîne(Fournisseurs.dateModification?? "JJJJ JJ MMM AAAA")
      sinon
      	Info("Enregistrement non trouvé")
      FIN
     type : 458752
