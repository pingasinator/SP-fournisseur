  -
    name : BTN_Valider
    identifier : 0x29c4f3bc38132586
    internal_properties : 
    properties :
     x : 492
     y : 535
     width : 103
     height : 30
     accelerator_key : 65535
     tab_order : 8
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description 
         // Bouton en validation
         
        type : 14
      -
        code : |1-
         //ESPACE CONTROLE SAISIE CONTACT
         Si SansEspace(SAI_nom) = "" OU SAI_nom = "" alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_Nom)
         FIN
         
         SI (SansEspace(SAI_AdresseMail) = "" OU SAI_AdresseMail = "") ET (SansEspace(SAI_Tel) = "" ou SAI_Tel = "" OU taille(SAI_Tel) <> 14) alors
         	LIB_MessageErreur = "L'adresse mail ou le téléphone est obligatoire"
         	RepriseSaisie(SAI_AdresseMail)
         FIN
         
         
         SAI_nom = Majuscule(SAI_nom)
         EcranVersFichier(FEN_NouveauContact,Contacts)
         Hajoute(contacts)
         
         info("Le nouveau contact " + gPoliceGras() + SAI_Prenom + " " + SAI_nom + gpoliceGras(faux) + " a été ajouté avec succès.")
         
         // Retour vers fiche fournisseur et chargement de la liste des contacts à jour
         ExécuteTraitement(FEN_FicheFournisseur, trtInit)
         
         // Fermeture de l'écran
         ferme(FEN_NouveauContact)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Annuler
    identifier : 0x29c4f3c738264f94
    internal_properties : 
    properties :
     x : 29
     y : 535
     width : 103
     height : 30
     take_focus : 0
     accelerator_key : 65535
     tab_order : 7
    type : 4
