  -
    name : BTN_Valider
    identifier : 0x2a169e5f1444f254
    internal_properties : 
    properties :
     x : 305
     y : 542
     width : 82
     height : 24
     accelerator_key : 65535
     tab_order : 12
     group : GR_BtnFicheContactEdition
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description
         // Bouton en validation
         
        type : 14
      -
        code : |1-
         
         si SansEspace(SAI_Prenom) = "" ou SAI_Prenom alors
         	LIB_MessageErreur = "Le prénom du contact est obligatoire."
         	RepriseSaisie(SAI_Prenom)
         fin
         
         si SansEspace(SAI_Nom) = "" ou SAI_Nom alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_Nom)
         fin
         
         si SansEspace(SAI_Tel) = "" ou SAI_Nom alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_Nom)
         fin
         
         si SansEspace(SAI_AdresseMail) = "" ou SAI_Nom alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_Nom)
         fin
         
         si SansEspace(SAI_Fonction) = "" ou SAI_Nom alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_Nom)
         fin
         
         ECRANVersFichier(FEN_FicheContact,Contacts)
         HModifie(Contacts)
         afficherConsultation()
         chargementFicheContact()
         FEN_FicheFournisseur.chargementListeContacts()
        type : 18
      -
        type : 161
        enabled : false
  -
    name : BTN_Supprimer
    identifier : 0x2a169e7915b055d1
    internal_properties : 
    properties :
     x : 152
     y : 542
     width : 102
     height : 24
     accelerator_key : 46
     tab_order : 10
     group : GR_BtnFicheContactConsultation
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description
         // Bouton au style Supprimer
         
         
        type : 14
      -
        code : |1+
         
         HLitRecherchePremier(Contacts,id,gIdContactEnCours)
         
         si HTrouve(Contacts) = vrai alors
         	HSupprime();
         	FEN_FicheFournisseur.chargementListeContacts();
         	Ferme(FEN_FicheContact);
         FIN
         
        type : 18
      -
        type : 161
        enabled : false
  -
