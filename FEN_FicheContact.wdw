  procedures :
   -
     name : afficherConsultation
     procedure_id : 1879862857114306681
     type_code : 14
     code : |1-
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure afficherConsultation() <UI>
      
      GR_FicheContact..EnSaisie = FAUX
      GR_BtnFicheContactConsultation..Visible = Vrai
      GR_BtnFicheContactEdition..Visible = FAUX
     type : 458752
   -
     name : chargementFicheContact
     procedure_id : 1879869157839154061
     type_code : 14
     code : |1-
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure chargementFicheContact()
      
      HLitRecherchePremier(Contacts,id,gIdContactEnCours)
      si HTrouve(Contacts) = Vrai alors
      	FichierVersEcran(FEN_FicheContact)
      sinon
      	Info("Enregistrement non trouvé")
      FIN
     type : 458752
   -
     name : afficherEdition
     procedure_id : 1879871008974159731
     type_code : 14
     code : |1-
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure afficherEdition()
      
      GR_FicheContact..EnSaisie				= Vrai
      GR_BtnFicheContactConsultation..Visible	= Faux
      GR_BtnFicheContactEdition..Visible		= Vrai
     type : 458752
