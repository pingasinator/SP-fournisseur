  -
    name : Annuler
    identifier : 0x29a5afaf05a15b47
    internal_properties : 
    properties :
     x : 28
     y : 619
     width : 87
     height : 24
     take_focus : 0
     accelerator_key : 65535
     tab_order : 18
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description 
         // Bouton en annulation
         
        type : 14
      -
        internal_properties : IQAAACAAAAAvPwxyIlyiHoyhQjTWU3KqmhtCHWMpvt1JFFhqSVoEVWvLoy7j3NqAh6SAoPBchAcL45moyQqkZrvT/+588Xw9uKzzeO9lSOh3WuU77Duzp4DhiGVdeC31UAkG+7Ccp6olwAw=
        code : |1+
         Ferme(FEN_NouveauFournisseur)
        type : 18
      -
        type : 161
        enabled : false
  -
    name : Valider
    identifier : 0x29a5afc005b49dce
    internal_properties : 
    properties :
     x : 948
     y : 619
     width : 87
     height : 24
     accelerator_key : 65535
     tab_order : 19
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description 
         // Bouton en validation
         
        type : 14
      -
        code : |1-
         //ESPACE CONTROLE DE SAISIE DU FOURNISSEUR
         si SansEspace(SAI_RaisonSociale) = "" ou SAI_RaisonSociale ="" alors
         	LIB_MessageErreur = "La raison sociale du fournisseur est obligatoire."
         	RepriseSaisie(SAI_RaisonSociale)
         FIN
         
         si SansEspace(SAI_codePostal) = "" ou SAI_codePostal ="" alors
         	LIB_MessageErreur = "Le code postal du fournisseur est obligatoire."
         	RepriseSaisie(SAI_codePostal)
         fin
         
         si Taille(SAI_codePostal) <> 5 alors
         	LIB_MessageErreur = "Le code postal doit contenir 5 caractères et uniquement 5."
         FIN
         
         si SansEspace(SAI_ville) = "" ou SAI_ville ="" alors
         	LIB_MessageErreur = "La ville du fournisseur est obligatoire."
         	RepriseSaisie(SAI_ville)
         fin
         
         si SansEspace(SAI_numSiret) = "" ou SAI_numSiret=""alors
         	LIB_MessageErreur = "Le numéro SIRET est obligatoire."
         	RepriseSaisie(SAI_numSiret)
         fin
         
         si Taille(SAI_numSiret) <> 14 ou EstNumérique(SAI_numSiret) = Faux alors
         	LIB_MessageErreur = "Le numéro Siret doit contenir uniquement 14 valeurs numériques."
         	RepriseSaisie(SAI_numSiret)
         FIN
         
         HLitRecherchePremier(Fournisseurs,numSiret,SAI_numSiret)
         si HTrouve(Fournisseurs) alors
         	si Fournisseurs.numSiret <> 0 alors
         		LIB_MessageErreur = "Un fournisseur possède déjà ce numéro Siret."
         		RepriseSaisie(SAI_numSiret)
         	FIN
         FIN
         
         
         si SansEspace(SAI_nom) = "" ou SAI_nom ="" alors
         	LIB_MessageErreur = "Le nom du contact est obligatoire."
         	RepriseSaisie(SAI_nom)
         fin
         
         si (SansEspace(SAI_adresseMail1) = "" ou SAI_adresseMail1 ="") et (SansEspace(SAI_tel1) = "" ou SAI_tel1 ="") alors
         	LIB_MessageErreur = "L'adresse mail ou le numéro de téléphone du contact est obligatoire."
         	RepriseSaisie(SAI_adresseMail1)
         fin
         
         // ESPACE ENREGISTREMENT EN BD => LE FOURNISSEUR
         SAI_ville = Majuscule(SAI_ville)
         SAI_RaisonSociale = Majuscule(SAI_RaisonSociale)
         
         EcranversFichier(FEN_NouveauFournisseur,Fournisseurs)
         HAjoute(Fournisseurs)
         
         // ESPACE ENREGISTREMENT EN BD => LE CONTACT
         Contacts.fournisseur_id = Fournisseurs.id
         Ecranversfichier(FEN_NouveauFournisseur,Contacts)
         HAjoute(Contacts)
         
         Info("Le fournisseur " + gPoliceGras() + SAI_RaisonSociale + gPoliceGras(FAux) + " a été ajouté avec succès.")
         
         //Attention à venir gérer la fermeture de la fenêtre et son retour
         
         ExécuteTraitement(FEN_ListeFournisseurs,trtInit)
         Ferme(FEN_NouveauFournisseur)
        type : 18
      -
        type : 161
        enabled : false
