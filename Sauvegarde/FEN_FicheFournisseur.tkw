  -
    name : BTN_Supprimer
    identifier : 0x29a991cd30a89e18
    internal_properties : 
    properties :
     x : 156
     y : 662
     width : 102
     height : 24
     accelerator_key : 46
     tab_order : 19
     group : GR_BtnFicheFournisseurConsultation
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description 
         // Bouton au style Supprimer
         
         
        type : 14
      -
        code : |1+
         
         HLitRecherchePremier(Fournisseurs,id,gIdFournisseurEnCours)
         
         si HTrouve(Fournisseurs) = Vrai alors
         	HSupprime();
         	FEN_ListeFournisseurs.chargementListeFournisseur();
         	Ferme(FEN_FicheFournisseur);
         fin
         
        type : 18
      -
        type : 161
        enabled : false
