  -
    name : BTN_Valider
    identifier : 0x29a995aa35a5b408
    internal_properties : 
    properties :
     x : 483
     y : 828
     width : 103
     height : 30
     accelerator_key : 65535
     tab_order : 21
     group : GR_BtnFicheFournisseurEdition
    type : 4
    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // Version 1
         // Description 
         // Bouton en validation
         
        type : 14
      -
        code : |1+
         
         saveSiret est une entier sur 8 octets
         saveSiret = SAI_NumSiret
         
         //ESPACE CONTROLE DE SAISIE DU FOURNISSEUR
         si SansEspace(SAI_RaisonSociale) = "" ou SAI_RaisonSociale ="" alors
         	LIB_MessageErreur = "La raison sociale du fournisseur est obligatoire."
         	RepriseSaisie(SAI_RaisonSociale)
         fin
         
         si SansEspace(SAI_CodePostal) = "" ou SAI_CodePostal ="" alors
         	LIB_MessageErreur = "Le code postal du fournisseur est obligatoire."
         	RepriseSaisie(SAI_RaisonSociale)
         fin
         
         si Taille(SAI_CodePostal) <> 5 alors
         	LIB_MessageErreur = "Le code postale doit contenir 5 caractères et uniquement 5."
         	RepriseSaisie(SAI_CodePostal)
         fin
         
         si SansEspace(SAI_Ville) = "" ou SAI_Ville ="" alors
         	LIB_MessageErreur = "La ville du fournisseur est obligatoire."
         	RepriseSaisie(SAI_Ville)
         fin
         
         Si saveSiret <> SAI_NumSiret alors
         	HlitRecherchePremier(Fournisseurs,numSiret,SAI_NumSiret)
         	Si Htrouve(Fournisseurs) alors
         		si Fournisseurs.numSiret <> 0 alors
         			LIB_MessageErreur	= "Un fournisseur a déjà été créé avec ce numéro Siret."
         			SAI_NumSiret		= saveSiret
         			RepriseSaisie(SAI_NumSiret)
         		fin
         	fin
         fin
         
         si Taille(SAI_NumSiret) <> 14 ou EstNumérique(SAI_NumSiret) = Faux alors
         	LIB_MessageErreur = "Le numéro Siret doit contenir uniquement 14 valeurs numériques"
         	RepriseSaisie(SAI_NumSiret)
         fin
         
         // ESPACE ENREGISTREMENT EN BD => LE FOURNISSEUR
         //Attention à ajouter aux spécifications : Raison sociale et ville toujours en majuscule
         SAI_RaisonSociale	= Majuscule(SAI_RaisonSociale)
         SAI_Ville			= Majuscule(SAI_Ville)
         
         ecranversfichier(FEN_FicheFournisseur, Fournisseurs)
         Hmodifie(Fournisseurs)
         Info("Le fournisseurs " + gPoliceGras() + SAI_RaisonSociale + gPoliceGras(faux) + " a correctement été modifié.")
         
         afficherConsultation()
         
         chargementFicheFournisseur()
         
         RepriseSaisie(SAI_RaisonSociale)
         
        type : 18
      -
        type : 161
        enabled : false
