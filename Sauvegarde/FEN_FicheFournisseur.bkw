  procedures :
   -
     name : afficherConsultation
     procedure_id : 1849192031830927388
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure afficherConsultation() <UI>
      
      
      GR_FicheFournisseur..EnSaisie = faux
      GR_BtnFicheFournisseurConsultation..Visible = vrai
      GR_BtnFicheFournisseurEdition..Visible = Faux
     type : 458752
   -
     name : chargementFicheFournisseur
     procedure_id : 1849196618872206363
     type_code : 14
     code : |1-
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure chargementFicheFournisseur()
      
      HLitRecherchePremier(Fournisseurs,id,gIdFournisseurEnCours)
      si HTrouve(Fournisseurs) = Vrai alors
      	FichierVersEcran(FEN_FicheFournisseur)
      
      	LIB_DateCreation		= "Fiche créée le : " + " " + DateVersChaîne(Fournisseurs.dateCreation?? "JJJJ JJ MMM AAAA")
      	LIB_DateModification	= "Fiche modifiée le : " + " " + DateVersChaîne(Fournisseurs.dateModification?? "JJJJ JJ MMM AAAA")
      
      sinon
      	Info("Enregistrement non trouvé")
      fin
     type : 458752
   -
     name : afficherEdition
     procedure_id : 1856869225707127058
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure afficherEdition()
      GR_FicheFournisseur..EnSaisie = Vrai
      GR_BtnFicheFournisseurConsultation..visible = faux
      GR_BtnFicheFournisseurEdition..visible = vrai
      
     type : 458752
   -
     name : chargementListeContacts
     procedure_id : 1856883467868330203
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure chargementListeContacts()
      
      // Déclaration des variables
      sdReqContacts est une source de données
      sql est une chaîne
      
      // Initialisation
      sql = [
      SELECT * FROM Contacts WHERE Contacts.fournisseur_id = %1
      ]
      sql = ChaîneConstruit(sql,gIdFournisseurEnCours)
      
      TableSupprimeTout(TABLE_ListeContacts)
      
      SAI_Commentaire = ""
      
      //Traitements
      SI PAs HExécuteRequêteSQL(sdReqContacts,sql) alors
      	Erreur("Erreur d'initialisation de la requête " + RC + HerreurInfo())
      	retour
      FIN
      
      HLitPremier(sdReqContacts)
      SI Htrouve(sdReqContacts)alors
      	TANTQUE HEnDehors(sdReqContacts) = Faux
      		Tableajoute(TABLE_ListeContacts, sdReqContacts.id + TAB + sdReqContacts.prenom + TAB + sdReqContacts.nom + TAB + sdReqContacts.adresseMail + TAB + sdReqContacts.tel)
      		Hlitsuivant(sdReqContacts)
      	FIN
      FIN
      
      TableSelectPlus(TABLE_ListeContacts,1)
      ExécuteTraitement(TABLE_ListeContacts,trtSélection)
      
     type : 458752
   -
     name : miseEnFormeSaisie
     procedure_id : 1856900596228699500
     type_code : 14
     code : |1+
      //!
      //! @brief <indiquez ici ce que fait la procédure>
      //!
      //!
      procédure miseEnFormeSaisie()
      
      Si GR_FicheFournisseur..EnSaisie = faux ALORS
      	SAI_RaisonSociale..SélectionEnAffichage			= Faux
      	SAI_IdentiteDestinataire..SélectionEnAffichage	= Faux
      	SAI_BatimentZi..SélectionEnAffichage			= Faux
      	SAI_NumLibVoie..SélectionEnAffichage			= Faux
      	SAI_MentionSpeciale..SélectionEnAffichage		= Faux
      	SAI_CodePostal..SélectionEnAffichage			= Faux
      	SAI_ville..SélectionEnAffichage					= Faux
      	SAI_tel..SélectionEnAffichage					= Faux
      	SAI_AdresseMail..SélectionEnAffichage			= Faux
      	SAI_NumSiret..SélectionEnAffichage				= Faux
      	SAI_UrlSite..SélectionEnAffichage				= Faux
      	SAI_ZoneObservation..SélectionEnAffichage		= Faux
      sinon
      	SAI_RaisonSociale..SélectionEnAffichage			= Vrai
      	SAI_IdentiteDestinataire..SélectionEnAffichage	= Vrai
      	SAI_BatimentZi..SélectionEnAffichage			= Vrai
      	SAI_NumLibVoie..SélectionEnAffichage			= Vrai
      	SAI_MentionSpeciale..SélectionEnAffichage		= Vrai
      	SAI_CodePostal..SélectionEnAffichage			= Vrai
      	SAI_Ville..SélectionEnAffichage					= Vrai
      	SAI_Tel..SélectionEnAffichage					= Vrai
      	SAI_AdresseMail..SélectionEnAffichage			= Vrai
      	SAI_NumSiret..SélectionEnAffichage				= Vrai
      	SAI_UrlSite..SélectionEnAffichage				= Vrai
      	SAI_ZoneObservation..SélectionEnAffichage		= Vrai
      FIN
     type : 458752
